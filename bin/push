#!/usr/bin/env bash
# push - 通过 Server 酱给 Qingyan 的微信推一条消息
# 用法:
#   push "标题"
#   push "标题" "正文（支持 Markdown）"
#   echo "正文" | push "标题"
# 退出码:
#   0 成功；非 0 时打印 Server 酱返回的错误信息

set -euo pipefail

SENDKEY_FILE="${SENDKEY_FILE:-$HOME/.config/openclaw-push/sendkey}"

if [[ ! -r "$SENDKEY_FILE" ]]; then
  echo "push: 找不到 SendKey 文件: $SENDKEY_FILE" >&2
  exit 2
fi

SENDKEY="$(cat "$SENDKEY_FILE")"
if [[ -z "$SENDKEY" ]]; then
  echo "push: SendKey 为空" >&2
  exit 2
fi

if [[ $# -lt 1 ]]; then
  echo "用法: push <标题> [正文]   或   echo 正文 | push <标题>" >&2
  exit 64
fi

TITLE="$1"
if [[ $# -ge 2 ]]; then
  DESP="$2"
elif [[ ! -t 0 ]]; then
  DESP="$(cat)"
else
  DESP=""
fi

RESP="$(curl -fsS \
  --connect-timeout 10 --max-time 30 \
  -X POST "https://sctapi.ftqq.com/${SENDKEY}.send" \
  --data-urlencode "title=${TITLE}" \
  --data-urlencode "desp=${DESP}" \
  || true)"

# 简单检查 code 字段
if echo "$RESP" | grep -q '"code"[[:space:]]*:[[:space:]]*0'; then
  echo "push: ok"
  exit 0
else
  echo "push: 推送失败" >&2
  echo "$RESP" >&2
  exit 1
fi
